# Environment template for the API test suite. Copy to .env and adjust.
# Real secrets must NEVER be committed (.env is git-ignored; only this template is tracked).

# Base URL of the API under test (OPEN QUESTION Q-6). No trailing slash required.
API_BASE_URL=http://localhost:8000

# HTTP client timeout, seconds.
HTTP_TIMEOUT=10

# Header name the integration endpoint uses for the API key (brief §4.5, Q-2).
API_KEY_HEADER=X-API-Key

# Admin authorization (OPEN QUESTION Q-4). Leave empty to treat admin endpoints as open.
# Example: ADMIN_AUTH_HEADER=Authorization  /  ADMIN_AUTH_TOKEN=Bearer <token>
ADMIN_AUTH_HEADER=
ADMIN_AUTH_TOKEN=

# Expected HTTP status for successful create operations (OPEN QUESTION Q-5): 201 or 200.
EXPECT_CREATED_CODE=201

# Extra requests beyond the per-minute limit when probing rate limiting (0 -> derive at runtime).
RATE_LIMIT_PROBE_COUNT=0

# Suite log level.
LOG_LEVEL=INFO

# ============================================================================================
# Application (FastAPI) settings — read by app/core/config.py. Override secrets in production.
# ============================================================================================
# Database. SQLite for dev; PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/amobile
DATABASE_URL=sqlite:///./app.db

# Admin auth (ADR-009). MUST be changed in production.
AUTH_ENABLED=true
JWT_SECRET=dev-insecure-jwt-secret-change-me
ACCESS_TOKEN_TTL_MINUTES=60
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# API key pepper (ADR-004). Server-side secret; MUST be changed in production.
API_KEY_PEPPER=dev-insecure-pepper-change-me

# Optional production backends (see requirements-optional.txt). Leave empty for in-process fallback.
REDIS_URL=
SENTRY_DSN=
LOG_JSON=false

